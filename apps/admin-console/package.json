{
  "name": "@local-wellness/admin-console",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ../../scripts/run-with-root-env.mjs node node_modules/next/dist/bin/next build",
    "dev": "node ../../scripts/run-with-root-env.mjs node node_modules/next/dist/bin/next dev --port 3004",
    "lint": "eslint .",
    "start": "node ../../scripts/run-with-root-env.mjs node node_modules/next/dist/bin/next start",
    "test": "node --test --import tsx test/*.test.ts",
    "typecheck": "next typegen && tsc -p tsconfig.json"
  },
  "dependencies": {
    "@local-wellness/config": "workspace:*",
    "@local-wellness/types": "workspace:*",
    "@supabase/ssr": "catalog:",
    "@supabase/supabase-js": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "eslint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
