{
  "name": "@local-wellness/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint .",
    "start": "node dist/main.js",
    "test": "node --test --import tsx src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@local-wellness/config": "workspace:*",
