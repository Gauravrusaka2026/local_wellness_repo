{
  "name": "@local-wellness/mobile",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "build": "node ../../scripts/run-with-root-env.mjs node node_modules/expo/bin/cli export --platform android --output-dir dist/app",
    "dev": "node ../../scripts/run-with-root-env.mjs node node_modules/expo/bin/cli start",
    "lint": "eslint .",
    "start": "node ../../scripts/run-with-root-env.mjs node node_modules/expo/bin/cli start",
    "test": "node --test --import tsx test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@expo/metro-runtime": "catalog:",
    "@local-wellness/api-client": "workspace:*",
    "@local-wellness/config": "workspace:*",
    "@local-wellness/localization": "workspace:*",
    "@local-wellness/types": "workspace:*",
    "@local-wellness/validation": "workspace:*",
    "@react-native-community/netinfo": "catalog:",
    "@supabase/supabase-js": "catalog:",
    "expo": "catalog:",
    "expo-audio": "catalog:",
    "expo-asset": "catalog:",
    "expo-camera": "catalog:",
    "expo-constants": "catalog:",
    "expo-crypto": "catalog:",
    "expo-file-system": "catalog:",
    "expo-image-manipulator": "catalog:",
    "expo-image-picker": "catalog:",
    "expo-linking": "catalog:",
    "expo-location": "catalog:",
    "expo-router": "catalog:",
    "expo-secure-store": "catalog:",
    "expo-sqlite": "catalog:",
    "expo-video-thumbnails": "catalog:",
    "expo-web-browser": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native": "catalog:",
    "react-native-gesture-handler": "catalog:",
    "react-native-reanimated": "catalog:",
    "react-native-safe-area-context": "catalog:",
    "react-native-screens": "catalog:",
    "react-native-url-polyfill": "catalog:",
    "react-native-worklets": "catalog:",
    "socket.io-client": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "eslint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
