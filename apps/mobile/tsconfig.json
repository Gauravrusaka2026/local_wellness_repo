{
  "extends": "../../packages/config/typescript/react-native.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.tsbuildinfo",
    "types": ["node", "react"]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "test/**/*.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
