{
  "name": "local-wellness",
  "version": "0.0.0",
  "private": true,
  "description": "Maharashtra-first civic complaint reporting and accountability platform.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.11.0 <12"
  },
  "scripts": {
    "access:bootstrap-platform-admin": "node scripts/bootstrap-platform-admin.mjs",
    "build": "turbo run build",
    "changeset": "changeset",
    "database:reset": "supabase db reset",
    "database:lint": "supabase db lint --local --schema public,private,governance,routing,complaints --level warning --fail-on error",
    "database:master:check": "node scripts/generate-master-migration.mjs --check",
    "database:master:generate": "node scripts/generate-master-migration.mjs",
    "database:start": "supabase start",
    "database:stop": "supabase stop",
    "database:test": "supabase test db",
    "database:types": "node scripts/generate-database-types.mjs",
    "database:types:check": "node scripts/generate-database-types.mjs --check",
    "dev": "turbo run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "governance:data:prepare": "corepack pnpm --filter @local-wellness/types build && corepack pnpm --filter @local-wellness/validation build",
    "governance:data:validate": "corepack pnpm governance:data:prepare && corepack pnpm --filter @local-wellness/database governance:validate",
    "governance:data:generate": "corepack pnpm governance:data:prepare && corepack pnpm --filter @local-wellness/database governance:generate",
    "governance:data:check": "corepack pnpm governance:data:prepare && corepack pnpm --filter @local-wellness/database governance:check",
    "http:load": "node scripts/http-check.mjs --mode=load",
    "http:smoke": "node scripts/http-check.mjs --mode=smoke",
    "lint": "turbo run lint",
    "prepare": "husky",
    "references:check": "tsc --build --pretty false",
    "release": "changeset publish",
    "security:secrets": "node scripts/check-secrets.mjs",
    "test": "turbo run test && node --test tests/*.test.mjs",
    "test:auth:e2e": "node --test tests/auth-flow.e2e.test.mjs",
    "typecheck": "turbo run typecheck && tsc --build --pretty false",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@eslint/js": "catalog:",
    "@types/node": "catalog:",
    "@supabase/supabase-js": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "globals": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "supabase": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
