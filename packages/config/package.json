{
  "name": "@local-wellness/config",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "typescript"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./typescript/base.json": "./typescript/base.json",
    "./typescript/node.json": "./typescript/node.json",
    "./typescript/nextjs.json": "./typescript/nextjs.json",
    "./typescript/react-native.json": "./typescript/react-native.json"
  },
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "test": "node --test test/*.test.mjs",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0"
  }
}
