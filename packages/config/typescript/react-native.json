{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Local Wellness React Native",
  "extends": "./base.json",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "customConditions": ["react-native"],
    "jsx": "react-jsx",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true
  }
}
